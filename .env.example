# Copy to .env.local and fill in. Never commit real values.

# Neon Postgres — pooled (app runtime)
DATABASE_URL=
# Neon Postgres — direct/unpooled (schema migrations)
DATABASE_URL_UNPOOLED=

# Auth session signing:        openssl rand -base64 32
AUTH_SECRET=
# Credential encryption (AES-256, server-only): openssl rand -base64 32
NEXUS_ENCRYPTION_KEY=

APP_URL=http://localhost:3005
